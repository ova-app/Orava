{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    // TS 6.0 : `baseUrl` est déprécié (erreur TS5101) et n'est plus requis —
    // `paths` est résolu relativement à ce fichier grâce à `moduleResolution: bundler`
    // (hérité de expo/tsconfig.base). Retirer baseUrl coupe l'inclusion automatique
    // des @types globaux, d'où le `types` explicite pour retrouver les globals de test.
    "types": ["jest", "node"],
    "paths": {
      "@/*": ["./*"]
    }
  }
}
